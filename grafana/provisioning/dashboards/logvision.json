  "annotations": { "list": [] },
  "description": "Apache access.log analytics — replicates LogVision heatmap, hourly distribution and top pages",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
